<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="LuminousToolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/app_background</item>
        <item name="android:elevation">0dp</item>
        <item name="android:paddingLeft">8dp</item>
        <item name="android:paddingRight">8dp</item>
        <item name="titleTextColor">@color/brand</item>
        <item name="titleTextAppearance">@style/LuminousToolbarTitle</item>
        <item name="navigationIconTint">@color/brand</item>
    </style>

    <style name="LuminousToolbarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/brand</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">22sp</item>
    </style>

    <style name="LuminousCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface_white</item>
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">1dp</item>
        <item name="strokeColor">@color/hairline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="LuminousOutlinedCard" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">@color/surface_white</item>
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/outline_variant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="LuminousPrimaryButton" parent="Widget.Material3.Button">
        <item name="android:layout_height">@dimen/primary_action_height</item>
        <item name="android:minHeight">@dimen/touch_target</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
        <item name="backgroundTint">@color/brand</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="LuminousDangerButton" parent="LuminousPrimaryButton">
        <item name="backgroundTint">@color/error</item>
    </style>

    <style name="LuminousSecondaryButton" parent="Widget.Material3.Button.TonalButton">
        <item name="android:minHeight">@dimen/touch_target</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/primary_fixed</item>
        <item name="android:textColor">@color/brand</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- 每页顶部大标题 -->
    <style name="PageTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">24sp</item>
        <item name="android:lineHeight">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- 标题下的一段功能说明 -->
    <style name="PageDesc">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/grid_4</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingExtra">3dp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- 卡片内的小标题 -->
    <style name="CardTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 输入框上方的灰色说明 -->
    <style name="FieldLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/space_12</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- 轻灰 filled 输入框；聚焦时才强调主色描边。 -->
    <style name="Field" parent="Widget.Material3.TextInputLayout.FilledBox.Dense">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/space_8</item>
        <item name="boxBackgroundColor">@color/surface_low</item>
        <item name="boxCornerRadiusTopStart">@dimen/field_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/field_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/field_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/field_radius</item>
        <item name="boxStrokeColor">@color/selector_field_stroke</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
    </style>

    <style name="LuminousStatusText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/brand</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="LuminousSectionLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/brand</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <!-- 设置首页的分类行：整行至少 72dp，点击目标不小于 48dp。 -->
    <style name="SettingsRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">72dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:paddingLeft">@dimen/space_16</item>
        <item name="android:paddingRight">@dimen/space_16</item>
        <item name="android:paddingTop">@dimen/space_16</item>
        <item name="android:paddingBottom">@dimen/space_16</item>
    </style>

    <style name="SettingsRowText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="SettingsRowTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SettingsRowDesc">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/grid_4</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="SettingsRowChevron">
        <item name="android:layout_width">@dimen/touch_target</item>
        <item name="android:layout_height">@dimen/touch_target</item>
        <item name="android:layout_marginLeft">@dimen/space_8</item>
        <item name="android:background">@drawable/ic_chevron_right_24</item>
        <item name="android:backgroundTint">@color/text_muted</item>
    </style>

</resources>
