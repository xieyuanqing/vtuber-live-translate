<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/pageInterp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 空闲态独立滚动；开始后整个容器隐藏。 -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/interpIdleContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/page_margin"
            android:paddingTop="@dimen/space_16"
            android:paddingBottom="@dimen/page_bottom_padding">

            <TextView
                style="@style/PageTitle"
                android:text="同传" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                android:background="@drawable/bg_language_pill"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/space_12"
                android:paddingVertical="@dimen/space_8">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:boxBackgroundMode="none"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:endIconMode="none"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/acInterpSourceLang"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:inputType="none"
                        android:padding="0dp"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/btnInterpSwapLang"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:text="⇄"
                    android:textColor="@color/brand"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:boxBackgroundMode="none"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:endIconMode="none"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/acInterpTargetLang"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:inputType="none"
                        android:padding="0dp"
                        android:textColor="@color/brand"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_24"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="176dp"
                    android:layout_height="176dp"
                    android:background="@drawable/bg_mic_halo"
                    android:padding="20dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnInterpToggle"
                        style="@style/LuminousPrimaryButton"
                        android:layout_width="136dp"
                        android:layout_height="136dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="开始同传"
                        app:cornerRadius="68dp"
                        app:icon="@drawable/ic_mic_white_24"
                        app:iconGravity="textTop"
                        app:iconPadding="8dp"
                        app:iconSize="36dp" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:background="@drawable/bg_status_pill"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/space_16"
                    android:paddingVertical="@dimen/space_8">

                    <View
                        android:layout_width="@dimen/status_dot_size"
                        android:layout_height="@dimen/status_dot_size"
                        android:background="@drawable/bg_idle_dot" />

                    <TextView
                        android:id="@+id/tvInterpStatus"
                        style="@style/LuminousStatusText"
                        android:layout_marginStart="@dimen/space_8"
                        android:text="待开始" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvInterpSubStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:text="麦克风实时同传"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 场景行：标签 + 摘要 + 场景库入口；chips 单行横滑。 -->
            <LinearLayout
                android:id="@+id/cardInterpPlan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_24"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/LuminousSectionLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="场景" />

                    <TextView
                        android:id="@+id/btnInterpOpenPlanLibrary"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:paddingHorizontal="@dimen/space_8"
                        android:text="场景库 ›"
                        android:textColor="@color/brand"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvInterpPlanSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/grid_4"
                    android:text="通用 · 自动 → 中文"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />

                <!-- 保留 ID，默认隐藏，不再展示 prompt 原文。 -->
                <TextView
                    android:id="@+id/tvInterpProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupInterpHomeScenes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:chipSpacingHorizontal="@dimen/space_8"
                        app:selectionRequired="true"
                        app:singleLine="true"
                        app:singleSelection="true" />
                </HorizontalScrollView>
            </LinearLayout>

            <!-- 本场背景：默认折叠一行入口。 -->
            <com.google.android.material.card.MaterialCardView
                style="@style/LuminousCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <LinearLayout
                        android:id="@+id/rowInterpSessionContextToggle"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvInterpSessionContextHeader"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="本场背景 · 可选 ›"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvInterpSessionContextSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/btnInterpClearSessionContext"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:gravity="center"
                            android:text="×"
                            android:textColor="@color/text_muted"
                            android:textSize="20sp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/interpSessionContextBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Field"
                            android:layout_marginTop="@dimen/space_8"
                            android:hint="本场背景与资料"
                            app:helperText="例如现场主题、说话人、专名提示">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etInterpSessionContext"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="top"
                                android:inputType="textCapSentences|textMultiLine"
                                android:minLines="3"
                                android:maxLines="7" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnInterpAnalyzeContext"
                            style="@style/LuminousSecondaryButton"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="@dimen/space_8"
                            android:text="AI 整理本场资料" />

                        <TextView
                            android:id="@+id/tvInterpAnalyzeStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_8"
                            android:text=""
                            android:textColor="@color/text_muted"
                            android:textSize="12sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 运行态：顶部状态和底部停止固定，只有字幕区域滚动。 -->
    <LinearLayout
        android:id="@+id/interpRunningContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/page_margin"
        android:paddingTop="@dimen/space_16"
        android:paddingBottom="@dimen/space_16"
        android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView style="@style/PageTitle" android:text="同传中" />

                <TextView
                    android:id="@+id/tvInterpElapsed"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="monospace"
                    android:gravity="end"
                    android:text="00:00"
                    android:textColor="@color/brand"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                style="@style/LuminousCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/viewInterpRunningStatusDot"
                            android:layout_width="@dimen/status_dot_size"
                            android:layout_height="@dimen/status_dot_size"
                            android:background="@drawable/bg_success_dot" />

                        <TextView
                            android:id="@+id/tvInterpRunningStatus"
                            style="@style/LuminousStatusText"
                            android:layout_marginStart="@dimen/space_8"
                            android:text="准备连接" />

                        <TextView
                            android:id="@+id/tvInterpAudioLevel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="monospace"
                            android:gravity="end"
                            android:text="0%"
                            android:textColor="@color/brand"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/pbInterpAudio"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="@dimen/space_12"
                        android:max="100"
                        android:progress="0"
                        android:progressBackgroundTint="@color/surface_high"
                        android:progressTint="@color/brand" />

                    <TextView
                        android:id="@+id/tvInterpRunningMeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:text="自动 → 中文 · 通用"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:overScrollMode="never">

            <com.google.android.material.card.MaterialCardView
                style="@style/LuminousCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <TextView style="@style/CardTitle" android:text="实时字幕" />

                    <LinearLayout
                        android:id="@+id/interpConfirmedList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:orientation="vertical" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_16"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="2dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_transcript_accent" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_12"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvInterpTargetLanguageLabel"
                                style="@style/FieldLabel"
                                android:layout_marginTop="0dp"
                                android:text="中文" />

                            <TextView
                                android:id="@+id/tvInterpZh"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/grid_4"
                                android:minHeight="56dp"
                                android:text="等待译文…"
                                android:textColor="@color/text_primary"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvInterpJa"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_8"
                                android:minHeight="32dp"
                                android:text="等待原文输入…"
                                android:textColor="@color/text_secondary"
                                android:textSize="15sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvInterpTranscriptPath"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_16"
                        android:text="自动保存到应用内历史"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnInterpPause"
                style="@style/LuminousSecondaryButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/primary_action_height"
                android:layout_marginEnd="@dimen/space_8"
                android:layout_weight="1"
                android:text="暂停" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnInterpStop"
                style="@style/LuminousDangerButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/primary_action_height"
                android:layout_weight="1"
                android:text="停止同传"
                app:icon="@drawable/ic_stop_white_24"
                app:iconGravity="textStart"
                app:iconPadding="@dimen/space_8" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
