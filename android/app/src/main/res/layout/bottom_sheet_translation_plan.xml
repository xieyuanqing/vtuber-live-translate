<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface_white"
    android:orientation="vertical"
    android:paddingBottom="16dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_sheet_handle" />

    <TextView
        android:id="@+id/tvPlanSheetTitle"
        style="@style/PageTitle"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:text="同传方案" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <TextView
                style="@style/FieldLabel"
                android:text="已保存方案" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="载入自定义方案">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/acPlanSaved"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                style="@style/FieldLabel"
                android:layout_marginTop="18dp"
                android:text="场景预设" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupPlanScenes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp"
                app:selectionRequired="true"
                app:singleSelection="true" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPlanCustomScene"
                style="@style/Field"
                android:hint="自定义场景说明"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPlanCustomScene"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:maxLines="5" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPlanVideoUrl"
                style="@style/Field"
                android:layout_marginTop="14dp"
                android:hint="本场视频链接"
                android:visibility="gone"
                app:helperText="支持 YouTube 链接；标题和频道仅用于本场资料整理">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPlanVideoUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:maxLines="2" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPlanSessionContext"
                style="@style/Field"
                android:layout_marginTop="12dp"
                android:hint="本场背景与资料"
                app:helperText="只在本场生效，停止后清除">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPlanSessionContext"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:inputType="textCapSentences|textMultiLine"
                    android:minLines="3"
                    android:maxLines="7" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAnalyzeContext"
                style="@style/LuminousSecondaryButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="AI 整理资料与术语" />

            <TextView
                android:id="@+id/tvAnalyzeStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="AI 结果会写入本场背景，并保存为可选术语库"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggleAdvanced"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:text="高级自定义  ›" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPlanCustom"
                style="@style/Field"
                android:hint="额外翻译要求"
                android:visibility="gone"
                app:helperText="只补充本模式提示词，不会覆盖内置安全与实时规则">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPlanCustom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:maxLines="7" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPlanName"
                style="@style/Field"
                android:hint="另存方案名称（可选）"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPlanName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSavePlan"
        style="@style/LuminousPrimaryButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="20dp"
        android:text="应用本场方案" />
</LinearLayout>
