<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_white"
    android:orientation="vertical"
    android:paddingBottom="@dimen/space_16">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/space_12"
        android:background="@drawable/bg_sheet_handle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="@dimen/space_8"
        android:layout_marginTop="@dimen/space_8"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvPlanSheetTitle"
            style="@style/PageTitle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="同传方案" />

        <ImageButton
            android:id="@+id/btnClosePlanSheet"
            android:layout_width="@dimen/touch_target"
            android:layout_height="@dimen/touch_target"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="关闭"
            android:padding="@dimen/space_12"
            android:src="@drawable/ic_close_24" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="@dimen/grid_4"
        android:text="方案是长期配置；本场临时背景仍在业务主页填写"
        android:textColor="@color/text_muted"
        android:textSize="13sp" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="@dimen/space_16"
            android:paddingBottom="@dimen/space_12">

            <TextView style="@style/LuminousSectionLabel" android:text="基础信息" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPlanName"
                style="@style/Field"
                android:layout_marginTop="@dimen/space_8"
                android:hint="方案名称"
                app:helperText="填写名称后会同步保存到方案库">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPlanName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_24"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/LuminousSectionLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="翻译场景" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnManageScenes"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/touch_target"
                    android:text="管理场景库"
                    android:textAllCaps="false"
                    android:textColor="@color/brand" />
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.FilledBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:hint="场景"
                app:boxBackgroundColor="@color/surface_low"
                app:boxCornerRadiusBottomEnd="@dimen/field_radius"
                app:boxCornerRadiusBottomStart="@dimen/field_radius"
                app:boxCornerRadiusTopEnd="@dimen/field_radius"
                app:boxCornerRadiusTopStart="@dimen/field_radius"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="1.5dp"
                app:helperText="场景提示词可在场景库中查看和编辑">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/acPlanScene"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                style="@style/LuminousSectionLabel"
                android:layout_marginTop="@dimen/space_24"
                android:text="高级设置" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPlanCustom"
                style="@style/Field"
                android:layout_marginTop="@dimen/space_8"
                android:hint="长期提示词"
                app:helperText="口吻、专名译法和表达风格会长期保存在方案里">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPlanCustom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:minLines="4"
                    android:maxLines="10" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSavePlan"
        style="@style/LuminousPrimaryButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="20dp"
        android:text="保存方案" />
</LinearLayout>
