<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface_white"
    android:orientation="vertical"
    android:paddingBottom="@dimen/space_16">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/space_12"
        android:background="@drawable/bg_sheet_handle" />

    <TextView
        android:id="@+id/tvPlanSheetTitle"
        style="@style/PageTitle"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="@dimen/space_16"
        android:text="同传方案" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="@dimen/space_12"
            android:paddingBottom="@dimen/space_12">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Field"
                android:hint="方案名称">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPlanName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                style="@style/FieldLabel"
                android:layout_marginTop="@dimen/space_16"
                android:text="场景预设" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupPlanScenes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp"
                app:selectionRequired="true"
                app:singleSelection="true" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPlanCustomScene"
                style="@style/Field"
                android:hint="自定义场景说明"
                android:visibility="gone"
                app:helperText="选择「自定义」时生效，会写入方案">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPlanCustomScene"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:maxLines="5" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPlanCustom"
                style="@style/Field"
                android:layout_marginTop="@dimen/space_12"
                android:hint="方案提示词"
                app:helperText="长期保存在方案里：术语、口吻、专名译法、风格要求都写这里">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPlanCustom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:minLines="5"
                    android:maxLines="12" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSavePlan"
        style="@style/LuminousPrimaryButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="20dp"
        android:text="保存并应用" />
</LinearLayout>
