<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorPrimary"
            android:minHeight="?attr/actionBarSize"
            android:theme="@style/ThemeOverlay.Material3.Dark.ActionBar"
            app:navigationIcon="@drawable/ic_menu_24"
            app:title="实时翻译" />

        <FrameLayout
            android:id="@+id/pageContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- ============ 页面：实时翻译 ============ -->
            <ScrollView
                android:id="@+id/pageLive"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="24dp">

                    <TextView
                        style="@style/PageTitle"
                        android:text="实时翻译" />

                    <TextView
                        style="@style/PageDesc"
                        android:text="捕获手机正在播放的直播声音，实时翻译成中文并用悬浮窗盖在视频上。开始前先在“主播资料”里选好主播、在“设置”里填好 Key。" />

                    <!-- 运行控制台 -->
                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.Material3.CardView.Filled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:cardCornerRadius="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvHeroStatus"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="○ 待开始"
                                        android:textColor="?attr/colorPrimary"
                                        android:textSize="20sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/tvHeroSubStatus"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="尚未开始翻译"
                                        android:textColor="?android:attr/textColorSecondary"
                                        android:textSize="12sp" />
                                </LinearLayout>

                                <TextView
                                    android:id="@+id/tvAudioLevel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="monospace"
                                    android:text="0%"
                                    android:textColor="?attr/colorPrimary"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:text="输入音量（有数字跳动说明已经捕到声音）"
                                android:textColor="?android:attr/textColorSecondary"
                                android:textSize="12sp" />

                            <ProgressBar
                                android:id="@+id/pbAudio"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="10dp"
                                android:layout_marginTop="6dp"
                                android:max="100"
                                android:progress="0"
                                android:progressBackgroundTint="#2A000000"
                                android:progressTint="?attr/colorPrimary" />

                            <Button
                                android:id="@+id/btnToggle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:paddingVertical="14dp"
                                android:text="开始翻译"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/tvCurrentProfile"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="当前主播：通用VTuber"
                                android:textColor="?android:attr/textColorSecondary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 当前会话字幕 -->
                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.Material3.CardView.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardCornerRadius="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                style="@style/CardTitle"
                                android:text="当前字幕" />

                            <TextView
                                style="@style/FieldLabel"
                                android:text="中文（悬浮窗同步显示）" />

                            <TextView
                                android:id="@+id/tvLiveZh"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:minHeight="52dp"
                                android:text="等待中文字幕…"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                style="@style/FieldLabel"
                                android:text="日文听写（原文，供对照）" />

                            <TextView
                                android:id="@+id/tvLiveJa"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:minHeight="40dp"
                                android:text="等待日文输入…"
                                android:textColor="?android:attr/textColorSecondary"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvTranscriptPath"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="本场记录会自动存到 下载/LiveTranslate/，也能在“历史记录”页查看。"
                                android:textColor="?android:attr/textColorSecondary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </ScrollView>

            <!-- ============ 页面：主播资料 ============ -->
            <ScrollView
                android:id="@+id/pageStreamer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="24dp">

                    <TextView
                        style="@style/PageTitle"
                        android:text="主播资料" />

                    <TextView
                        style="@style/PageDesc"
                        android:text="这里是“固定提示词”——描述主播是谁、术语怎么翻。保存后长期复用。下面还能填“临时提示词”，只对本场直播生效，不会保存。" />

                    <!-- 资料库选择 -->
                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.Material3.CardView.Filled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:cardCornerRadius="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                style="@style/CardTitle"
                                android:text="选择主播" />

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense.ExposedDropdownMenu"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:hint="已保存的主播资料">

                                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                    android:id="@+id/acStreamerProfile"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="none"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <Button
                                    android:id="@+id/btnNewStreamer"
                                    style="@style/Widget.Material3.Button.TextButton"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="新建主播" />

                                <Button
                                    android:id="@+id/btnSaveStreamer"
                                    style="@style/Widget.Material3.Button.TextButton"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="保存资料" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 固定资料 -->
                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.Material3.CardView.Filled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardCornerRadius="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                style="@style/CardTitle"
                                android:text="固定提示词 · 主播资料" />

                            <TextView
                                style="@style/FieldLabel"
                                android:text="资料名是列表里的显示名，必填。其它字段可留空。" />

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Field"
                                android:hint="资料名（如：風真いろは）">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etStreamerKey"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="text"
                                    android:maxLines="1"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Field"
                                android:hint="日文名（可选）">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etStreamerNameJp"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="text"
                                    android:maxLines="1"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Field"
                                android:hint="中文名（可选）">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etStreamerNameZh"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="text"
                                    android:maxLines="1"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense.ExposedDropdownMenu"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:hint="分类（可选，可直接输入）">

                                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                    android:id="@+id/acStreamerCategory"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="text"
                                    android:maxLines="1"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Field"
                                android:hint="所属 / 人设（如：hololive 6期生 / 侍）">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etStreamerAffiliation"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="text"
                                    android:maxLines="2"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Field"
                                android:hint="别名 / 口癖（每行一个）">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etStreamerAliases"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="top"
                                    android:inputType="textMultiLine"
                                    android:minLines="2"
                                    android:textSize="13sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Field"
                                android:hint="术语固定译法（每行一个，如 holoX = holoX）">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etStreamerTerms"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="top"
                                    android:inputType="textMultiLine"
                                    android:minLines="3"
                                    android:textSize="13sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Field"
                                android:hint="常见错听修正（每行一个，如 風間→風真）">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etStreamerMisheard"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="top"
                                    android:inputType="textMultiLine"
                                    android:minLines="2"
                                    android:textSize="13sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Field"
                                android:hint="翻译风格（可选，一句话）">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etStreamerStyle"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="top"
                                    android:inputType="textMultiLine"
                                    android:minLines="2"
                                    android:textSize="13sp" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 临时提示词 -->
                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.Material3.CardView.Filled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardCornerRadius="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                style="@style/CardTitle"
                                android:text="临时提示词 · 仅本场" />

                            <TextView
                                style="@style/FieldLabel"
                                android:text="只影响接下来这一场直播，不会保存进主播资料。可以贴 YouTube 链接自动带出标题/频道，或手动补一句本场内容。" />

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Field"
                                android:hint="YouTube 链接（可选）">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etYoutubeUrl"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="textUri"
                                    android:maxLines="2"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <Button
                                android:id="@+id/btnFetchYoutube"
                                style="@style/Widget.Material3.Button.TonalButton"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="从链接获取标题和频道" />

                            <TextView
                                android:id="@+id/tvYoutubeInfo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="未获取直播信息"
                                android:textColor="?android:attr/textColorSecondary"
                                android:textSize="12sp" />

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Field"
                                android:hint="本场内容补充（可选，如：睡前杂谈、聊新专辑）">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etTempContext"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="top"
                                    android:inputType="textMultiLine"
                                    android:minLines="2"
                                    android:textSize="13sp" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 提示词预览 -->
                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.Material3.CardView.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardCornerRadius="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                style="@style/CardTitle"
                                android:text="提示词预览" />

                            <TextView
                                style="@style/FieldLabel"
                                android:text="点“预览”看看开播时实际发给模型的完整内容（固定资料 + 临时提示词）。开始翻译时会自动用这套，无需手动应用。" />

                            <Button
                                android:id="@+id/btnPreviewPrompt"
                                style="@style/Widget.Material3.Button.TonalButton"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="预览完整提示词" />

                            <TextView
                                android:id="@+id/tvPromptPreview"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:fontFamily="monospace"
                                android:text="（点上面按钮生成预览）"
                                android:textColor="?android:attr/textColorSecondary"
                                android:textIsSelectable="true"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </ScrollView>

            <!-- ============ 页面：历史记录 ============ -->
            <ScrollView
                android:id="@+id/pageHistory"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="24dp">

                    <TextView
                        style="@style/PageTitle"
                        android:text="历史记录" />

                    <TextView
                        style="@style/PageDesc"
                        android:text="每场翻译都会自动存一份（日文原文 + 中文），在这里点开就能回看。同一份也在 下载/LiveTranslate/ 里，可用文件管理器分享。" />

                    <Button
                        android:id="@+id/btnRefreshHistory"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="刷新列表" />

                    <TextView
                        android:id="@+id/tvHistoryEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="还没有历史记录。翻译一场之后再回来看看。"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/historyList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardHistoryDetail"
                        style="@style/Widget.Material3.CardView.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:visibility="gone"
                        app:cardCornerRadius="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:id="@+id/tvHistoryTitle"
                                style="@style/CardTitle"
                                android:text="记录内容" />

                            <Button
                                android:id="@+id/btnCopyHistory"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="end"
                                android:text="复制全文" />

                            <TextView
                                android:id="@+id/tvHistoryDetail"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="monospace"
                                android:text=""
                                android:textIsSelectable="true"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </ScrollView>

            <!-- ============ 页面：设置 ============ -->
            <ScrollView
                android:id="@+id/pageSettings"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="24dp">

                    <TextView
                        style="@style/PageTitle"
                        android:text="设置" />

                    <TextView
                        style="@style/PageDesc"
                        android:text="连接 Gemini 用的 Key 和悬浮窗外观。改完直接返回“实时翻译”开始即可。" />

                    <!-- 连接 -->
                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.Material3.CardView.Filled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:cardCornerRadius="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                style="@style/CardTitle"
                                android:text="连接" />

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:hint="Gemini API Key"
                                app:helperText="可填多个，用英文逗号分隔，每次开播随机用一个分摊配额">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etApiKeys"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:importantForAutofill="no"
                                    android:inputType="textVisiblePassword"
                                    android:maxLines="2"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:hint="API Base URL"
                                app:helperText="默认是官方地址，用反代时才需要改">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etBaseUrl"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:importantForAutofill="no"
                                    android:inputType="textUri"
                                    android:maxLines="1"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 悬浮窗样式 -->
                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.Material3.CardView.Filled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardCornerRadius="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                style="@style/CardTitle"
                                android:text="悬浮窗样式" />

                            <TextView
                                style="@style/FieldLabel"
                                android:text="翻译进行时拖动调整都会即时生效。" />

                            <TextView
                                android:id="@+id/tvFontVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="字号 16sp"
                                android:textSize="13sp" />

                            <com.google.android.material.slider.Slider
                                android:id="@+id/slFont"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:stepSize="1"
                                android:valueFrom="12"
                                android:valueTo="26" />

                            <TextView
                                android:id="@+id/tvOpacityVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="背景不透明度 66%"
                                android:textSize="13sp" />

                            <com.google.android.material.slider.Slider
                                android:id="@+id/slOpacity"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:stepSize="5"
                                android:valueFrom="20"
                                android:valueTo="95" />

                            <TextView
                                android:id="@+id/tvLinesVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="最多行数 3"
                                android:textSize="13sp" />

                            <com.google.android.material.slider.Slider
                                android:id="@+id/slLines"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:stepSize="1"
                                android:valueFrom="1"
                                android:valueTo="3" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </ScrollView>

            <!-- ============ 页面：诊断 ============ -->
            <ScrollView
                android:id="@+id/pageDiagnostics"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="24dp">

                    <TextView
                        style="@style/PageTitle"
                        android:text="诊断" />

                    <TextView
                        style="@style/PageDesc"
                        android:text="出问题时看这里：连接状态、发送块数、最近字幕。也可以把本 App 加进电池白名单，降低被系统杀后台的概率。" />

                    <Button
                        android:id="@+id/btnBattery"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="加入电池白名单" />

                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.Material3.CardView.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardCornerRadius="16dp">

                        <TextView
                            android:id="@+id/tvStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:padding="14dp"
                            android:text="○ 未运行"
                            android:textSize="12sp" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:lineSpacingExtra="3dp"
                        android:text="流程：设置填 Key → 主播资料选主播 → 实时翻译点开始 → 同意录音/通知/屏幕录制 → 切到 YouTube。\n悬浮窗：可拖动；点一下收成小圆点，再点展开。圆点绿=已连接、黄=连接中、红=出错。"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </ScrollView>
        </FrameLayout>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/drawer_menu" />
</androidx.drawerlayout.widget.DrawerLayout>
