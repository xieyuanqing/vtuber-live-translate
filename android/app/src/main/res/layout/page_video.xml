<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/pageVideo"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone">

    <!-- 空闲态：滚动区 + 底部固定 CTA；根 ID 保留供整根显隐。 -->
    <LinearLayout
        android:id="@+id/videoIdleContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/page_margin"
                android:paddingTop="@dimen/space_16"
                android:paddingBottom="@dimen/space_16">

                <TextView style="@style/PageTitle" android:text="视频" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:background="@drawable/bg_language_pill"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/space_12"
                    android:paddingVertical="@dimen/space_8">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:boxBackgroundMode="none"
                        app:boxStrokeWidth="0dp"
                        app:boxStrokeWidthFocused="0dp"
                        app:endIconMode="none"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/acVideoSourceLang"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@android:color/transparent"
                            android:gravity="center"
                            android:inputType="none"
                            android:padding="0dp"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/btnVideoSwapLang"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:gravity="center"
                        android:text="⇄"
                        android:textColor="@color/brand"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:boxBackgroundMode="none"
                        app:boxStrokeWidth="0dp"
                        app:boxStrokeWidthFocused="0dp"
                        app:endIconMode="none"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/acVideoTargetLang"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@android:color/transparent"
                            android:gravity="center"
                            android:inputType="none"
                            android:padding="0dp"
                            android:textColor="@color/brand"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- 缺权限时警告横幅；已授权时控制器整行 GONE。 -->
                <LinearLayout
                    android:id="@+id/rowOverlayPermission"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:background="@drawable/bg_warning_banner"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/space_16"
                    android:paddingVertical="@dimen/space_12"
                    android:visibility="gone">

                    <View
                        android:id="@+id/viewOverlayPermissionDot"
                        android:layout_width="@dimen/status_dot_size"
                        android:layout_height="@dimen/status_dot_size"
                        android:background="@drawable/bg_warning_dot" />

                    <TextView
                        android:id="@+id/tvOverlayPermissionStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_12"
                        android:layout_weight="1"
                        android:text="悬浮字幕未授权"
                        android:textColor="@color/warning"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnOverlayPermissionSettings"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:paddingHorizontal="@dimen/space_8"
                        android:text="去设置"
                        android:textColor="@color/warning"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 场景行 + 横滑 chips -->
                <LinearLayout
                    android:id="@+id/cardVideoPlan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_24"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            style="@style/LuminousSectionLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="场景" />

                        <TextView
                            android:id="@+id/btnVideoOpenPlanLibrary"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:gravity="center"
                            android:paddingHorizontal="@dimen/space_8"
                            android:text="场景库 ›"
                            android:textColor="@color/brand"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvVideoPlanSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/grid_4"
                        android:text="通用视频 · 自动 → 中文"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvCurrentProfile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:overScrollMode="never"
                        android:scrollbars="none">

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chipGroupVideoHomeScenes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:chipSpacingHorizontal="@dimen/space_8"
                            app:selectionRequired="true"
                            app:singleLine="true"
                            app:singleSelection="true" />
                    </HorizontalScrollView>
                </LinearLayout>

                <!-- 本场视频：默认折叠 -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/LuminousCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_16">

                        <LinearLayout
                            android:id="@+id/rowVideoSessionContextToggle"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvVideoSessionContextHeader"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="本场视频 · 可选 ›"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvVideoSessionContextSummary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_muted"
                                android:textSize="12sp"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/btnVideoClearSessionContext"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:gravity="center"
                                android:text="×"
                                android:textColor="@color/text_muted"
                                android:textSize="20sp"
                                android:visibility="gone" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/videoSessionContextBody"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Field"
                                android:layout_marginTop="@dimen/space_8"
                                android:hint="YouTube 链接（用于 AI 解析背景）">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etVideoSessionUrl"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="textUri"
                                    android:maxLines="2" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                style="@style/Field"
                                android:layout_marginTop="@dimen/space_12"
                                android:hint="本场背景与资料">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etVideoSessionContext"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="top"
                                    android:inputType="textCapSentences|textMultiLine"
                                    android:minLines="3"
                                    android:maxLines="7" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnVideoAnalyzeContext"
                                style="@style/LuminousSecondaryButton"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="@dimen/space_8"
                                android:text="AI 解析本场视频" />

                            <TextView
                                android:id="@+id/tvVideoAnalyzeStatus"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_8"
                                android:text=""
                                android:textColor="@color/text_muted"
                                android:textSize="12sp"
                                android:visibility="gone" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnToggle"
            style="@style/LuminousPrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/primary_action_height"
            android:layout_marginHorizontal="@dimen/page_margin"
            android:layout_marginTop="@dimen/space_8"
            android:layout_marginBottom="@dimen/space_16"
            android:text="开始视频字幕"
            app:icon="@drawable/ic_nav_video_24"
            app:iconGravity="textStart"
            app:iconPadding="@dimen/space_8"
            app:iconTint="@color/brand_on" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/videoRunningContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/page_margin"
        android:paddingTop="@dimen/space_16"
        android:paddingBottom="@dimen/space_16"
        android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView style="@style/PageTitle" android:text="视频字幕" />

                <TextView
                    android:id="@+id/tvVideoElapsed"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="monospace"
                    android:gravity="end"
                    android:text="00:00"
                    android:textColor="@color/brand"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                style="@style/LuminousCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/viewVideoRunningStatusDot"
                            android:layout_width="@dimen/status_dot_size"
                            android:layout_height="@dimen/status_dot_size"
                            android:background="@drawable/bg_success_dot" />

                        <TextView
                            android:id="@+id/tvHeroStatus"
                            style="@style/LuminousStatusText"
                            android:layout_marginStart="@dimen/space_8"
                            android:text="准备连接" />

                        <TextView
                            android:id="@+id/tvAudioLevel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="monospace"
                            android:gravity="end"
                            android:text="0%"
                            android:textColor="@color/brand"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvHeroSubStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:text="其他应用音频 · 悬浮字幕"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <ProgressBar
                        android:id="@+id/pbAudio"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="@dimen/space_12"
                        android:max="100"
                        android:progress="0"
                        android:progressBackgroundTint="@color/surface_high"
                        android:progressTint="@color/brand" />

                    <TextView
                        android:id="@+id/tvVideoRunningMeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:text="自动 → 中文 · 通用视频"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:overScrollMode="never">

            <com.google.android.material.card.MaterialCardView
                style="@style/LuminousCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <TextView style="@style/CardTitle" android:text="实时字幕" />

                    <LinearLayout
                        android:id="@+id/videoConfirmedList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:orientation="vertical" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_16"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="2dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_transcript_accent" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_12"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvVideoTargetLanguageLabel"
                                style="@style/FieldLabel"
                                android:layout_marginTop="0dp"
                                android:text="中文" />

                            <TextView
                                android:id="@+id/tvLiveZh"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/grid_4"
                                android:minHeight="56dp"
                                android:text="等待译文…"
                                android:textColor="@color/text_primary"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvLiveJa"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_8"
                                android:minHeight="32dp"
                                android:text="等待原文输入…"
                                android:textColor="@color/text_secondary"
                                android:textSize="15sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvTranscriptPath"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_16"
                        android:text="自动保存到应用内历史"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVideoPause"
                style="@style/LuminousSecondaryButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/primary_action_height"
                android:layout_marginEnd="@dimen/space_8"
                android:layout_weight="1"
                android:text="暂停" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVideoStop"
                style="@style/LuminousDangerButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/primary_action_height"
                android:layout_weight="1"
                android:text="停止视频字幕"
                app:icon="@drawable/ic_stop_white_24"
                app:iconGravity="textStart"
                app:iconPadding="@dimen/space_8" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
