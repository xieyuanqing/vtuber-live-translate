<?xml version="1.0" encoding="utf-8"?>
            <ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
                android:id="@+id/pageVideo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/page_margin"
                    android:paddingTop="@dimen/space_24"
                    android:paddingBottom="@dimen/page_bottom_padding">

                    <TextView
                        style="@style/PageTitle"
                        android:text="视频字幕" />

                    <TextView
                        style="@style/PageDesc"
                        android:text="捕获其他应用正在播放的声音，实时生成悬浮翻译字幕。" />

                    <com.google.android.material.card.MaterialCardView
                        style="@style/LuminousCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:cardCornerRadius="@dimen/card_radius">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                style="@style/CardTitle"
                                android:text="翻译语言" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <com.google.android.material.textfield.TextInputLayout
                                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense.ExposedDropdownMenu"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:hint="源语言">

                                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                        android:id="@+id/acVideoSourceLang"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:inputType="none"
                                        android:textSize="15sp"
                                        android:textStyle="bold" />
                                </com.google.android.material.textfield.TextInputLayout>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginHorizontal="8dp"
                                    android:text="→"
                                    android:textColor="?attr/colorPrimary"
                                    android:textSize="24sp"
                                    android:textStyle="bold" />

                                <com.google.android.material.textfield.TextInputLayout
                                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense.ExposedDropdownMenu"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:hint="目标语言">

                                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                        android:id="@+id/acVideoTargetLang"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:inputType="none"
                                        android:textSize="15sp"
                                        android:textStyle="bold" />
                                </com.google.android.material.textfield.TextInputLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardVideoPlan"
                        style="@style/LuminousOutlinedCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:minHeight="72dp"
                        app:cardCornerRadius="@dimen/card_radius">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    style="@style/CardTitle"
                                    android:text="视频方案" />

                                <TextView
                                    android:id="@+id/tvVideoPlanSummary"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="通用视频 · 自动 → 中文"
                                    android:textColor="@color/text_muted"
                                    android:textSize="13sp" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:padding="8dp"
                                android:text="›"
                                android:textColor="@color/brand"
                                android:textSize="28sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 运行控制台 -->
                    <com.google.android.material.card.MaterialCardView
                        style="@style/LuminousCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:cardCornerRadius="@dimen/card_radius">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvHeroStatus"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="○ 待开始"
                                        android:textColor="?attr/colorPrimary"
                                        android:textSize="20sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/tvHeroSubStatus"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="尚未开始翻译"
                                        android:textColor="?android:attr/textColorSecondary"
                                        android:textSize="12sp" />
                                </LinearLayout>

                                <TextView
                                    android:id="@+id/tvAudioLevel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="monospace"
                                    android:text="0%"
                                    android:textColor="?attr/colorPrimary"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="14dp"
                                android:text="输入音量"
                                android:textColor="?android:attr/textColorSecondary"
                                android:textSize="12sp" />

                            <ProgressBar
                                android:id="@+id/pbAudio"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="10dp"
                                android:layout_marginTop="6dp"
                                android:max="100"
                                android:progress="0"
                                android:progressBackgroundTint="#2A000000"
                                android:progressTint="?attr/colorPrimary" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnToggle"
                                style="@style/LuminousPrimaryButton"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/primary_action_height"
                                android:layout_marginTop="16dp"
                                android:text="开始视频字幕"
                                app:icon="@drawable/ic_nav_video_24"
                                app:iconGravity="textStart"
                                app:iconPadding="8dp"
                                app:iconTint="@color/brand_on" />

                            <TextView
                                android:id="@+id/tvCurrentProfile"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="场景：通用视频"
                                android:textColor="?android:attr/textColorSecondary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 当前会话字幕 -->
                    <com.google.android.material.card.MaterialCardView
                        style="@style/LuminousOutlinedCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardCornerRadius="@dimen/card_radius">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                style="@style/CardTitle"
                                android:text="当前字幕" />

                            <TextView
                                android:id="@+id/tvVideoTargetLanguageLabel"
                                style="@style/FieldLabel"
                                android:text="中文" />

                            <TextView
                                android:id="@+id/tvLiveZh"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:minHeight="52dp"
                                android:text="等待译文…"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                style="@style/FieldLabel"
                                android:text="原文" />

                            <TextView
                                android:id="@+id/tvLiveJa"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:minHeight="40dp"
                                android:text="等待原文输入…"
                                android:textColor="?android:attr/textColorSecondary"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvTranscriptPath"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="自动存档于 下载/LiveTranslate/"
                                android:textColor="?android:attr/textColorSecondary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </ScrollView>
